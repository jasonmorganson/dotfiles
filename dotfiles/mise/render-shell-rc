#!/bin/sh
set -eu

shell_quote() {
    printf "'"
    printf "%s" "$1" | sed "s/'/'\\\\''/g"
    printf "'"
}

atomic_write() {
    target=$1
    dir=$(dirname "$target")
    mkdir -p "$dir"
    tmp=$(mktemp "${target}.tmp.XXXXXX")
    cat > "$tmp"
    mv "$tmp" "$target"
}

ls_colors=$(vivid --color-mode 8-bit generate one-dark)
ls_colors_quoted=$(shell_quote "$ls_colors")

render_posix() {
    shell=$1
    target=$2

    {
        printf '# Generated by mise bootstrap. Do not edit directly.\n'
        printf 'export LS_COLORS=%s\n\n' "$ls_colors_quoted"
        mise exec fnox -- fnox activate "$shell"
        printf '\n'
        mise exec pitchfork -- pitchfork activate "$shell"
        printf '\n'
        mise exec github:max-sixty/worktrunk -- wt config shell init "$shell"
        printf '\n'
        mise exec starship -- starship init "$shell" --print-full-init
    } | atomic_write "$target"
}

render_fish() {
    {
        printf '# Generated by mise bootstrap. Do not edit directly.\n'
        printf 'set -gx LS_COLORS %s\n\n' "$ls_colors_quoted"
        mise exec fnox -- fnox activate fish
        printf '\n'
        mise exec pitchfork -- pitchfork activate fish
        printf '\n'
        mise exec github:max-sixty/worktrunk -- wt config shell init fish
        printf '\n'
        mise exec starship -- starship init fish --print-full-init
    } | atomic_write "$HOME/.config/fish/conf.d/local.fish"
}

render_nushell_env() {
    {
        printf '# Generated by mise bootstrap. Do not edit directly.\n'
        printf '$env.LS_COLORS = %s\n' "$ls_colors_quoted"
    } | atomic_write "$HOME/.config/nushell/local.env.nu"
}

render_posix bash "$HOME/.config/bash/rc"
render_posix zsh "$HOME/.config/zsh/rc"
render_fish
render_nushell_env
