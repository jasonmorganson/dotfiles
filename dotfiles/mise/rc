#!/bin/sh
set -eu

quote() {
    sed "s/'/'\\\\''/g; 1s/^/'/; \$s/\$/'/"
}

ls_colors=$(vivid --color-mode 8-bit generate one-dark | quote)

write() {
    target=$1
    mkdir -p "${target%/*}"
    cat > "$target"
}

init_tools() {
    shell=$1
    mise exec fnox -- fnox activate "$shell"
    printf '\n'
    mise exec pitchfork -- pitchfork activate "$shell"
    printf '\n'
    mise exec github:max-sixty/worktrunk -- wt config shell init "$shell"
    printf '\n'
    mise exec starship -- starship init "$shell" --print-full-init
}

{
    printf '# Generated by mise bootstrap. Do not edit directly.\n'
    printf 'export LS_COLORS=%s\n\n' "$ls_colors"
    init_tools bash
} | write "$HOME/.config/bash/rc"

{
    printf '# Generated by mise bootstrap. Do not edit directly.\n'
    printf 'export LS_COLORS=%s\n\n' "$ls_colors"
    init_tools zsh
} | write "$HOME/.config/zsh/rc"

{
    printf '# Generated by mise bootstrap. Do not edit directly.\n'
    printf 'set -gx LS_COLORS %s\n\n' "$ls_colors"
    init_tools fish
} | write "$HOME/.config/fish/conf.d/local.fish"

{
    printf '# Generated by mise bootstrap. Do not edit directly.\n'
    printf '$env.LS_COLORS = %s\n' "$ls_colors"
} | write "$HOME/.config/nushell/local.env.nu"
