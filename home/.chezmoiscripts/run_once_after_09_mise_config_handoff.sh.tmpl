#!/bin/sh
set -eu

link_mise_file() {
    source=$1
    target=$2

    mkdir -p "$(dirname "$target")"

    if [ -L "$target" ] && [ "$(readlink "$target")" = "$source" ]; then
        return
    fi

    if [ -e "$target" ] || [ -L "$target" ]; then
        if [ ! -L "$target" ] && cmp -s "$source" "$target"; then
            rm -f "$target"
        else
            mv "$target" "${target}.before-mise-self-manage-$(date +%Y%m%d%H%M%S)"
        fi
    fi

    ln -s "$source" "$target"
}

link_mise_file {{ joinPath .chezmoi.sourceDir ".." "dotfiles/mise/config.toml" | quote }} "$HOME/.config/mise/config.toml"
link_mise_file {{ joinPath .chezmoi.sourceDir ".." "dotfiles/mise/mise.lock" | quote }} "$HOME/.config/mise/mise.lock"
