#!/bin/sh
set -eu

mkdir -p "$HOME/.cache/terminfo" "$HOME/.terminfo"
infocmp -x xterm-ghostty 2>/dev/null | sed '2s/^xterm-ghostty|ghostty|Ghostty,/xterm-ghostty|Ghostty terminal,/' > "$HOME/.cache/terminfo/xterm-ghostty.terminfo" || true
find "$HOME/.cache/terminfo" -name '*.terminfo' -type f -exec tic -x -o "$HOME/.terminfo" {} \;
