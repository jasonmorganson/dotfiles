#!/bin/sh
set -eu

quote() {
    sed "s/'/'\\\\''/g; 1s/^/'/; \$s/\$/'/"
}

ls_colors=$(vivid --color-mode 8-bit generate one-dark)
ls_colors=$(printf '%s\n' "$ls_colors" | quote)

write() {
    target=$1
    shift
    mkdir -p "${target%/*}"
    tmp=$(mktemp "${target}.tmp.XXXXXX")
    trap 'rm -f "$tmp"' 0 1 2 15

    "$@" > "$tmp"

    if cmp -s "$tmp" "$target"; then
        rm -f "$tmp"
    else
        mv "$tmp" "$target"
    fi

    trap - 0 1 2 15
}

init_tools() {
    shell=$1
    fnox activate "$shell"
    printf '\n'
    pitchfork activate "$shell"
    printf '\n'
    wt config shell init "$shell"
    printf '\n'
    starship init "$shell" --print-full-init
}

render_shell() {
    shell=$1
    printf '# Generated by mise bootstrap. Do not edit directly.\n'

    case "$shell" in
        fish) printf 'set -gx LS_COLORS %s\n\n' "$ls_colors" ;;
        nushell) printf '$env.LS_COLORS = %s\n' "$ls_colors"; return ;;
        *) printf 'export LS_COLORS=%s\n\n' "$ls_colors" ;;
    esac

    init_tools "$shell"
}

for shell in bash zsh; do
    write "$HOME/.config/$shell/rc" render_shell "$shell"
done

write "$HOME/.config/fish/conf.d/local.fish" render_shell fish
write "$HOME/.config/nushell/local.env.nu" render_shell nushell
