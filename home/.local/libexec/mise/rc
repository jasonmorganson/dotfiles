#!/bin/sh
set -eu

write() {
    target=$1
    shift
    mkdir -p "${target%/*}"
    tmp=$(mktemp "${target}.tmp.XXXXXX")
    trap 'rm -f "$tmp"' 0 1 2 15

    "$@" > "$tmp"

    if cmp -s "$tmp" "$target"; then
        rm -f "$tmp"
    else
        mv "$tmp" "$target"
    fi

    chmod 600 "$target"
    trap - 0 1 2 15
}

render_shell() {
    shell=$1
    printf '# Generated by mise bootstrap. Do not edit directly.\n'
    fnox activate "$shell"
    printf '\n'
    pitchfork activate "$shell"
    printf '\n'
    wt config shell init "$shell"
    printf '\n'
    starship init "$shell" --print-full-init
}

render_nushell_env() {
    printf '# Generated by mise bootstrap. Do not edit directly.\n'
    (
        unset MISE_SHELL __MISE_DIFF
        mise activate nu --no-hook-env
    )
    printf '\nmise_hook\n'
}

render_nushell_config() {
    printf '# Generated by mise bootstrap. Do not edit directly.\n'
    starship init nu
    printf '\n'
    fnox activate nu
    printf '\n'
    wt config shell init nu
}

for shell in bash zsh; do
    write "$HOME/.config/$shell/rc" render_shell "$shell"
done

write "$HOME/.config/fish/conf.d/local.fish" render_shell fish
write "$HOME/.config/nushell/env.nu" render_nushell_env
write "$HOME/.config/nushell/config.nu" render_nushell_config
