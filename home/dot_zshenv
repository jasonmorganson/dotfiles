export ZDOTDIR="$HOME/.config/zsh"

# Keep core XDG paths available before interactive shell init runs.
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"

# Seed a few high-value tool paths early so non-mise processes stay out of $HOME.
export PYTHONSTARTUP="$XDG_CONFIG_HOME/python/pythonrc"
export RENDER_CLI_CONFIG_PATH="$XDG_CONFIG_HOME/render/cli.yaml"
export WAKATIME_HOME="$XDG_CONFIG_HOME/wakatime"
export NPM_CONFIG_USERCONFIG="$XDG_CONFIG_HOME/npm/npmrc"
export NPM_CONFIG_PREFIX="$XDG_DATA_HOME/npm"
export NPM_CONFIG_CACHE="$XDG_CACHE_HOME/npm"
export npm_config_cache="$XDG_CACHE_HOME/npm"
