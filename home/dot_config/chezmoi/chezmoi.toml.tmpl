[env]
    PATH = {{ list (joinPath .chezmoi.homeDir ".local/bin") "/usr/local/bin" "/usr/bin" "/usr/sbin" "/bin" "/sbin" | join ":" | quote }}

{{ $output := output "sh" "-c" "mise exec aqua:cli/cli -- gh api user 2>/dev/null || true" }}
{{- with (merge (dict "id" "" "name" "" "login" "") ((and $output (fromJson $output)) | default (dict))) }}
[data.github]
    id = {{ printf "%v" .id | quote }}
    name = {{ .name | quote }}
    login = {{ .login | quote }}
{{- end }}

[git]
    autoCommit = true
    autoPush = true
