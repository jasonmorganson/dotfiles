---
# Set these before applying chezmoi, or edit this file after apply:
#   SYMPHONY_LINEAR_PROJECT_SLUG
#   SYMPHONY_SOURCE_REPO_URL
tracker:
  kind: linear
  project_slug: {{ env "SYMPHONY_LINEAR_PROJECT_SLUG" | default "REPLACE_ME_LINEAR_PROJECT_SLUG" | quote }}
polling:
  interval_ms: 5000
workspace:
  root: ~/.codex/symphony-workspaces
hooks:
  after_create: |
    git clone --depth 1 {{ env "SYMPHONY_SOURCE_REPO_URL" | default "REPLACE_ME_SOURCE_REPO_URL" | quote }} .
    if command -v mise >/dev/null 2>&1; then
      mise trust
      mise install
    fi
agent:
  max_concurrent_agents: 10
  max_turns: 20
codex:
  command: "$CODEX_BIN app-server --model gpt-5.3-codex"
  approval_policy: never
  thread_sandbox: workspace-write
  turn_sandbox_policy:
    type: workspaceWrite
---

