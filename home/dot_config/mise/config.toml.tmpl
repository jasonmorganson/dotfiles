[settings]
lockfile = true

[tools]
gh = "latest"
fzf = "latest"
fnox = "latest"
helix = "latest"
gitui = "latest"
git-lfs = "latest"
chezmoi = "latest"
pitchfork = "latest"
starship = "latest"
vivid = "latest"
cargo-binstall = "latest"
"cargo:git-delta" = "latest"
{{- if or (ne .chezmoi.os "linux") (eq .chezmoi.arch "amd64") }}
"aqua:reemus-dev/gitnr" = "latest"
{{- end }}
"github:lsd-rs/lsd" = "latest"
"aqua:BurntSushi/ripgrep" = "latest"
"github:max-sixty/worktrunk" = "latest"

[tools."github:MitMaro/git-interactive-rebase-tool"]
version = "latest"
[tools."github:MitMaro/git-interactive-rebase-tool".platforms]
macos-arm64 = { asset_pattern = "git-interactive-rebase-tool-*-macos-*_arm" }
macos-x64 = { asset_pattern = "git-interactive-rebase-tool-*-macos-*_intel" }
linux-x64 = { asset_pattern = "git-interactive-rebase-tool-*-ubuntu-*_amd64.deb" }
linux-arm64 = { asset_pattern = "git-interactive-rebase-tool-*-ubuntu-*_arm64.deb" }

[bootstrap.repos]
"~/.local/share/mise/repos/gitalias" = { url = "https://github.com/GitAlias/gitalias.git", ref = "main" }
"~/.config/nushell/scripts/nu_scripts" = { url = "https://github.com/nushell/nu_scripts.git" }
"~/.local/share/symphony" = { url = "https://github.com/openai/symphony.git" }

[bootstrap.mise_shell_activate]
zsh = true
bash = true
fish = true

[dotfiles]
