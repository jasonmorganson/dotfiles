[tools."github:MitMaro/git-interactive-rebase-tool"]
version = "latest"
[tools."github:MitMaro/git-interactive-rebase-tool".platforms]
macos-arm64 = { asset_pattern = "git-interactive-rebase-tool-*-macos-*_arm" }
macos-x64 = { asset_pattern = "git-interactive-rebase-tool-*-macos-*_intel" }
linux-x64 = { asset_pattern = "git-interactive-rebase-tool-*-ubuntu-*_amd64.deb" }
