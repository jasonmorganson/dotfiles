fzf = "latest"
fnox = "latest"
delta = "latest"
helix = "latest"
gitui = "latest"
git-lfs = "latest"
chezmoi = "latest"
pitchfork = "latest"
starship = "latest"
cargo-binstall = "latest"
"github:max-sixty/worktrunk" = "latest"
"github:lsd-rs/lsd" = "latest"
