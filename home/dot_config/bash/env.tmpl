# This file is referenced by BASH_ENV, so bash sources it for every
# non-interactive script. Run mise activation here, but preserve a usable PATH
# if mise rejects an untrusted project config during activation.
__bash_env_original_path="${PATH:-}"
if [ -z "$__bash_env_original_path" ]; then
  __bash_env_original_path="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
fi

case ":$__bash_env_original_path:" in
  *:"$HOME/.local/bin":*) ;;
  *) __bash_env_original_path="$HOME/.local/bin:$__bash_env_original_path" ;;
esac

PATH="$__bash_env_original_path"
export PATH

if command -v mise >/dev/null 2>&1; then
  __bash_env_mise_activate="$(mise activate bash 2>/dev/null)" &&
    eval "$__bash_env_mise_activate" ||
    PATH="$__bash_env_original_path"
  export PATH
  unset __bash_env_mise_activate
fi

case ":$PATH:" in
  *:/usr/bin:*) ;;
  *) PATH="$PATH:/usr/bin" ;;
esac
case ":$PATH:" in
  *:/bin:*) ;;
  *) PATH="$PATH:/bin" ;;
esac
case ":$PATH:" in
  *:/usr/sbin:*) ;;
  *) PATH="$PATH:/usr/sbin" ;;
esac
case ":$PATH:" in
  *:/sbin:*) ;;
  *) PATH="$PATH:/sbin" ;;
esac

export PATH
unset __bash_env_original_path
