# BASH_ENV is sourced by every non-interactive bash script. Activate mise
# without the eager hook-env pass so untrusted project configs cannot rewrite
# PATH before the script body starts.
PATH="$HOME/.local/bin:${PATH:-/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin}:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
export PATH

if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate bash --no-hook-env 2>/dev/null)"
fi
