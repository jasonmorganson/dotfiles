# This file is referenced by BASH_ENV, so bash sources it for every
# non-interactive script. Keep it minimal: full mise activation can rewrite
# PATH before failing on an untrusted project config, which leaves scripts
# without basic commands such as dirname.
if [ -z "${PATH:-}" ]; then
  PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
else
  case ":$PATH:" in
    *:/usr/bin:*) ;;
    *) PATH="$PATH:/usr/bin" ;;
  esac
  case ":$PATH:" in
    *:/bin:*) ;;
    *) PATH="$PATH:/bin" ;;
  esac
  case ":$PATH:" in
    *:/usr/sbin:*) ;;
    *) PATH="$PATH:/usr/sbin" ;;
  esac
  case ":$PATH:" in
    *:/sbin:*) ;;
    *) PATH="$PATH:/sbin" ;;
  esac
fi

case ":$PATH:" in
  *:"$HOME/.local/bin":*) ;;
  *) PATH="$HOME/.local/bin:$PATH" ;;
esac

export PATH
