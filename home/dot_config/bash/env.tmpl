# BASH_ENV is sourced by every non-interactive bash script. Keep mise active,
# but do not let an activation error leave scripts without basic commands.
__bash_env_path="${PATH:-/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin}"
PATH="$HOME/.local/bin:$__bash_env_path:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
export PATH

if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate bash 2>/dev/null)" || PATH="$__bash_env_path"
fi

PATH="$PATH:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
export PATH
unset __bash_env_path
