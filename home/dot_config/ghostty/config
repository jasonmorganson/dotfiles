theme = GitHub Dark

font-family = Hack
font-size = 13

title = " "

command = /opt/homebrew/bin/fish --login --interactive
shell-integration-features = sudo,ssh-terminfo

macos-option-as-alt = true
macos-titlebar-style = tabs
macos-titlebar-proxy-icon = hidden

keybind = cmd+enter=unbind
keybind = shift+enter=text:\x1b\r
keybind = shift+escape=toggle_split_zoom
keybind = global:ctrl+alt+grave_accent=toggle_quick_terminal
