{{- $mise := joinPath (env "HOME") ".local/bin/mise" -}}

{{ output $mise "activate" .SHELL }}

{{ output $mise "exec" "starship" "--" "starship" "init" .SHELL }}

{{- $supported := list "bash" "fish" "zsh" "powershell" -}}
{{- if in $supported .SHELL -}}
{{ output $mise "exec" "cargo:worktree" "--" "wt" "config" "shell" "init" .SHELL }}
{{- end -}}
